{
  "name": "photos.joneisen.me",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:photos": "node scripts/fetch-photos.js",
    "extract-exif": "node scripts/extract-exif.js",
    "set-cover": "node scripts/set-cover.js",
    "thumbnails": "node scripts/generate-thumbnails.js",
    "upload": "node scripts/upload-photos.js && npm run extract-exif",
    "build:site": "vite build",
    "build": "npm run build:photos && npm run build:site",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.712.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.4.7",
    "gh-pages": "^6.2.0",
    "vite": "^6.0.5",
    "wrangler": "^4.73.0"
  }
}
